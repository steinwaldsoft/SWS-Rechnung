<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} – " : "")SWS-Rechnung</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="sws-nav">
    <div class="sws-nav__inner">
        <!-- Logo -->
        <a class="sws-logo" asp-controller="Home" asp-action="Index">
            <div class="sws-logo__mark">
                <span class="s1">S</span><span class="sw">W</span><span class="s2">S</span>
            </div>
            <div class="sws-logo__text">
                <span class="sws-logo__main">steinwald.soft</span>
                <span class="sws-logo__sub">CRM · Angebote · Rechnungen</span>
            </div>
        </a>

        <button class="sws-nav__toggle" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <i class="bi bi-list"></i>
        </button>

        <div class="collapse sws-nav__menu" id="navMenu">
            <a class="sws-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"sws-nav__link--active":"")"
               asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="sws-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Kunden"?"sws-nav__link--active":"")"
               asp-controller="Kunden" asp-action="Index">
                <i class="bi bi-people"></i> Kunden
            </a>
            <a class="sws-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Angebote"?"sws-nav__link--active":"")"
               asp-controller="Angebote" asp-action="Index">
                <i class="bi bi-file-earmark-text"></i> Angebote
            </a>
            <a class="sws-nav__link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Rechnungen"?"sws-nav__link--active":"")"
               asp-controller="Rechnungen" asp-action="Index">
                <i class="bi bi-receipt"></i> Rechnungen
            </a>
            <a class="sws-nav__link sws-nav__link--icon @(ViewContext.RouteData.Values["action"]?.ToString()=="Einstellungen"?"sws-nav__link--active":"")"
               asp-controller="Home" asp-action="Einstellungen" title="Einstellungen">
                <i class="bi bi-gear-fill"></i>
            </a>
        </div>
    </div>
</nav>

<main class="sws-main">
    @if (TempData["Success"] != null)
    {
        <div class="sws-alert sws-alert--success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Success"]</span>
            <button class="sws-alert__close" data-bs-dismiss="alert"><i class="bi bi-x"></i></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="sws-alert sws-alert--error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@TempData["Error"]</span>
            <button class="sws-alert__close" data-bs-dismiss="alert"><i class="bi bi-x"></i></button>
        </div>
    }
    @RenderBody()
</main>

<footer class="sws-footer">
    <span>&copy; @DateTime.Now.Year steinwald.soft GmbH &mdash; SWS-Rechnung</span>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
