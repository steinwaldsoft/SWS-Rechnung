@model SWSRechnung.Models.Angebot
@using SWSRechnung.Models
@{
    ViewData["Title"] = Model.Angebotsnummer;
    string SB(string s) => s switch {
        "Entwurf"=>"<span class='badge badge--entwurf'>Entwurf</span>",
        "Versendet"=>"<span class='badge badge--versendet'>Versendet</span>",
        "Angenommen"=>"<span class='badge badge--angenommen'>Angenommen</span>",
        "Abgelehnt"=>"<span class='badge badge--abgelehnt'>Abgelehnt</span>",
        "Abgelaufen"=>"<span class='badge badge--abgelaufen'>Abgelaufen</span>",
        _=>$"<span class='badge badge--entwurf'>{s}</span>"
    };
}

<div class="page-header">
    <div>
        <div class="page-header__sub"><a asp-controller="Home" asp-action="Index">Dashboard</a> › <a asp-action="Index">Angebote</a> › @Model.Angebotsnummer</div>
        <div class="page-header__title">
            <i class="bi bi-file-earmark-text"></i> @Model.Angebotsnummer
            @Html.Raw(SB(Model.Status.ToString()))
        </div>
        @if (!string.IsNullOrEmpty(Model.Betreff)) { <div class="page-header__sub">@Model.Betreff</div> }
    </div>
    <div class="page-header__actions">
        <a asp-action="Word" asp-route-id="@Model.Id" class="btn-sws btn-sws--sm" style="background:#2B579A;" target="_blank" title="Word-Dokument (.docx)"><i class="bi bi-file-earmark-word"></i> Word</a>
        <a asp-action="Bearbeiten" asp-route-id="@Model.Id" class="btn-sws btn-sws--outline btn-sws--sm"><i class="bi bi-pencil"></i> Bearbeiten</a>
        @if (Model.Status == AngebotStatus.Versendet || Model.Status == AngebotStatus.Angenommen)
        {
            <form asp-action="AlsRechnung" asp-route-id="@Model.Id" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button class="btn-sws btn-sws--gruen btn-sws--sm" onclick="return confirmAct('Angebot als Rechnung übernehmen?')">
                    <i class="bi bi-receipt"></i> Als Rechnung
                </button>
            </form>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <!-- Empfänger -->
        <div class="sws-card mb-3">
            <div class="sws-card__head sws-card__head--light"><i class="bi bi-building"></i> Empfänger</div>
            <div class="sws-card__body">
                <div class="row">
                    <div class="col-md-6">
                        <strong>@Model.Kunde?.Firmenname</strong><br/>
                        @if (!string.IsNullOrEmpty(Model.Kunde?.Ansprechpartner)) { <span>@Model.Kunde.Anrede @Model.Kunde.Ansprechpartner<br/></span> }
                        @if (!string.IsNullOrEmpty(Model.Kunde?.Strasse)) { <span>@Model.Kunde.Strasse<br/></span> }
                        @Model.Kunde?.PLZ @Model.Kunde?.Ort
                    </div>
                    <div class="col-md-6 text-md-end mt-3 mt-md-0">
                        <div class="detail-grid" style="grid-template-columns:auto auto;">
                            <span class="detail-item__label">Datum</span>
                            <span class="detail-item__val">@Model.Angebotsdatum.ToString("dd.MM.yyyy")</span>
                            @if (Model.GueltigBis.HasValue) {
                                <span class="detail-item__label">Gültig bis</span>
                                <span class="detail-item__val @(Model.GueltigBis<DateTime.Today?"text-danger":"")">@Model.GueltigBis.Value.ToString("dd.MM.yyyy")</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.Kunde?.Kundennummer)) {
                                <span class="detail-item__label">Kundennr.</span>
                                <span class="detail-item__val fw-mono">@Model.Kunde.Kundennummer</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Einleitung)) {
        <div class="sws-card mb-3">
            <div class="sws-card__body" style="white-space:pre-line;font-size:.9rem;">@Model.Einleitung</div>
        </div>
        }

        <!-- Positionen -->
        <div class="sws-card mb-3">
            <div class="sws-card__head sws-card__head--gruen"><i class="bi bi-list-ol"></i> Positionen</div>
            <div class="table-responsive">
                <table class="sws-table">
                    <thead><tr>
                        <th style="width:40px;">Pos.</th><th>Bezeichnung</th><th class="text-end">Menge</th><th>Einh.</th>
                        <th class="text-end">Einzelpr.</th><th class="text-end">Rabatt</th><th class="text-end">Gesamt</th>
                    </tr></thead>
                    <tbody>
                    @foreach (var p in Model.Positionen.OrderBy(p=>p.Position))
                    {
                        <tr>
                            <td class="text-center text-muted">@p.Position</td>
                            <td>
                                <div class="fw-bold">@p.Bezeichnung</div>
                                @if (!string.IsNullOrEmpty(p.Beschreibung)) { <div class="text-muted" style="font-size:.8rem;">@p.Beschreibung</div> }
                            </td>
                            <td class="text-end fw-mono">@p.Menge.ToString("N3")</td>
                            <td>@p.Einheit</td>
                            <td class="text-end fw-mono">@p.Einzelpreis.ToString("C")</td>
                            <td class="text-end text-muted">@(p.Rabatt>0?p.Rabatt.ToString("N2")+"%":"–")</td>
                            <td class="text-end fw-mono fw-bold">@p.Gesamtpreis.ToString("C")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Schlusstext)) {
        <div class="sws-card">
            <div class="sws-card__body" style="white-space:pre-line;font-size:.875rem;">@Model.Schlusstext</div>
        </div>
        }
    </div>

    <div class="col-lg-4">
        <!-- Summen -->
        <div class="sws-card mb-3">
            <div class="sws-card__head"><i class="bi bi-calculator"></i> Betragsübersicht</div>
            <div class="p-0">
                <div class="summen-box">
                    <div class="summen-row"><span>Nettobetrag</span><span class="fw-mono fw-bold">@Model.Nettobetrag.ToString("C")</span></div>
                    <div class="summen-row"><span>MwSt. (@Model.MwStSatz.ToString("F0") %)</span><span class="fw-mono">@Model.MwStBetrag.ToString("C")</span></div>
                    <div class="summen-row summen-row--total"><span>Gesamtbetrag</span><span class="fw-mono">@Model.Bruttobetrag.ToString("C")</span></div>
                </div>
            </div>
        </div>

        <!-- Status ändern -->
        <div class="sws-card mb-3">
            <div class="sws-card__head sws-card__head--light"><i class="bi bi-arrow-repeat"></i> Status ändern</div>
            <div class="sws-card__body">
                <form asp-action="StatusAendern" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <select name="status" class="form-select form-select-sm mb-2">
                        @foreach (AngebotStatus s in Enum.GetValues(typeof(AngebotStatus)))
                        {
                            if (Model.Status == s)
                            { <option value="@((int)s)" selected>@s</option> }
                            else
                            { <option value="@((int)s)">@s</option> }
                        }
                    </select>
                    <button type="submit" class="btn-sws btn-sws--sm w-100">Status setzen</button>
                </form>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notizen)) {
        <div class="sws-card mb-3">
            <div class="sws-card__head sws-card__head--light"><i class="bi bi-sticky"></i> Interne Notizen</div>
            <div class="sws-card__body" style="font-size:.875rem;white-space:pre-line;">@Model.Notizen</div>
        </div>
        }

        <div class="sws-card">
            <div class="sws-card__head sws-card__head--light"><i class="bi bi-gear"></i> Aktionen</div>
            <div class="sws-card__body">
                <form asp-action="Loeschen" asp-route-id="@Model.Id" method="post" onsubmit="return confirmDel('@Model.Angebotsnummer')">
                    @Html.AntiForgeryToken()
                    <button class="btn-sws btn-sws--sm w-100" style="background:#e74c3c;" type="submit"><i class="bi bi-trash"></i> Angebot löschen</button>
                </form>
            </div>
        </div>
    </div>
</div>
